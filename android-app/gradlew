#!/bin/sh
# Gradle wrapper script
# این اسکریپت Gradle را به صورت خودکار دانلود و اجرا می‌کند
DIRNAME=$(dirname "$0")
APP_HOME=$(cd "$DIRNAME" || exit; pwd)

# دانلود gradle-wrapper.jar اگر وجود ندارد
if [ ! -f "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" ]; then
    echo "Downloading Gradle wrapper..."
    curl -sL "https://github.com/gradle/gradle/raw/v8.1.0/gradle/wrapper/gradle-wrapper.jar" -o "$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
fi

# استفاده از gradle wrapper یا gradle سیستم
if command -v gradle >/dev/null 2>&1; then
    gradle "$@"
else
    java -cp "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
fi
